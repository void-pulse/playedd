# Copy this file to .env and fill in your keys. NEVER commit .env.
# .env is already in .gitignore.

# fal.ai - get from https://fal.ai/dashboard/keys
FAL_KEY=

# ElevenLabs - get from https://elevenlabs.io  (Profile -> API Keys)
ELEVENLABS_API_KEY=

# OpenAI - only needed if you generate scripts via the OpenAI API instead of Claude.
# Optional. Leave blank if you write scripts in Claude Code.
OPENAI_API_KEY=
